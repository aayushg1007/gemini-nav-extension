{
  "manifest_version": 3,
  "name": "Gemini Chat Navigator Pro",
  "version": "1.1",
  "description": "Adds an accessibility sidebar to navigate Gemini queries.",
  "permissions": ["tabs", "webNavigation"],
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ]
}